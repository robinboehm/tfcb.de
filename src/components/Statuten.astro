---
const dokumente = [
  {
    titel: 'Satzung',
    beschreibung: 'Vereinssatzung vom 21.05.2016',
    url: 'https://docs.google.com/document/d/1zcFqySy28Wv53sUCb7fG53IlWQUTrvTzzR9sE4Rom9s/export?format=pdf',
  },
  {
    titel: 'Vereinsordnung',
    beschreibung: 'Vereinsordnung vom 07.11.2022',
    url: 'https://docs.google.com/document/d/1VEk9MaYpAT28NdsnZAwHImDlF6rTrT8OdtXP3PGpdyY/export?format=pdf',
  },
  {
    titel: 'Beitragsordnung',
    beschreibung: 'Beitragsordnung vom 10.03.2026',
    url: 'https://docs.google.com/document/d/1hM902Y0_ejYadC2CyRaJO7YJjL7Cdsn34DFubqPIrLA/export?format=pdf',
  },
];
---

<section id="statuten" class="section-dark-2">
  <div class="container">
    <h2 class="section-title">
      Unsere <span class="section-title-green">Statuten</span>
    </h2>
    <p class="section-subtitle">Satzung und Ordnungen des 1. TFC Berlin e.V.</p>

    <div class="statuten-grid">
      {dokumente.map(dok => (
        <a class="statut-card" href={dok.url} target="_blank" rel="noopener">
          <div class="statut-icon">📄</div>
          <div class="statut-info">
            <div class="statut-titel">{dok.titel}</div>
            <div class="statut-beschreibung">{dok.beschreibung}</div>
          </div>
          <div class="statut-download">PDF ↓</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .statuten-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .statut-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(76, 175, 80, 0.15);
    border-radius: 12px;
    padding: 1.5rem;
    color: var(--color-text-light);
    transition: border-color 0.2s, background 0.2s;
  }

  .statut-card:hover {
    border-color: var(--color-green);
    background: rgba(76, 175, 80, 0.06);
    color: var(--color-text-light);
  }

  .statut-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .statut-info {
    flex: 1;
    min-width: 0;
  }

  .statut-titel {
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }

  .statut-beschreibung {
    font-size: 0.85rem;
    color: var(--color-text-muted-dark);
  }

  .statut-download {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-green);
    white-space: nowrap;
  }
</style>
